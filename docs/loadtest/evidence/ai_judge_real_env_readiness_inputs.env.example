# AI Judge real-env readiness input template
# Copy the values into docs/loadtest/evidence/ai_judge_p5_real_env.env
# or export them in the shell before running ai_judge_real_env_window_closure.sh.
# Keep every *_READY=false until the linked evidence has been produced and reviewed.

REAL_CALIBRATION_ENV_READY=false
LOCAL_REFERENCE_ENV_READY=false
CALIBRATION_ENV_MODE=real

# Real sample manifest. The manifest must point to reviewed, privacy-redacted
# real debate samples and must be explicitly validated before marking ready.
REAL_SAMPLE_MANIFEST=
REAL_SAMPLE_MANIFEST_READY=false
REAL_SAMPLE_MANIFEST_EVIDENCE=

# Real provider and callback readiness. Do not use local mock/provider evidence.
REAL_PROVIDER_READY=false
REAL_PROVIDER_EVIDENCE=
REAL_CALLBACK_READY=false
REAL_CALLBACK_EVIDENCE=

# Production artifact store readiness must come from artifact_store_healthcheck.py
# with productionReady=true. Do not use local_reference output as readiness.
PRODUCTION_ARTIFACT_STORE_READY=false
PRODUCTION_ARTIFACT_STORE_EVIDENCE_JSON=docs/loadtest/evidence/ai_judge_artifact_store_healthcheck.json

# Target freezes. Mark true only after thresholds and evidence links are frozen.
BENCHMARK_TARGETS_READY=false
BENCHMARK_TARGETS_EVIDENCE=
FAIRNESS_TARGETS_READY=false
FAIRNESS_TARGETS_EVIDENCE=
RUNTIME_OPS_TARGETS_READY=false
RUNTIME_OPS_TARGETS_EVIDENCE=

# Evidence links carried into closure output.
LOCAL_REFERENCE_EVIDENCE_LINK=docs/loadtest/evidence/ai_judge_p5_local_reference_notes.md
REAL_EVIDENCE_LINK=
